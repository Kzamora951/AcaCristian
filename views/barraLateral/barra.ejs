<script>
(function () {
    // Mapa: clave -> rutas que activan ese semestre
    var semestres = {
        fundamentos: ['/primersemestre', '/gramatica_visual', '/diseno_bidimensional', '/principios_diseno', '/naturaleza_objetos'],
        teoria:      ['/segundosemestre', '/epistemologia', '/pensamientoDiseno', '/historiaImpacto'],
        diseno:      ['/tercersemestre', '/fisica_escultura', '/biomecanica', '/objeto_contexto']
    };

    function abrirSemestre(key) {
        var trigger = document.getElementById('trigger-' + key);
        var panel   = document.getElementById('panel-' + key);
        var icon    = document.getElementById('icon-' + key);
        var btn     = trigger ? trigger.querySelector('.barra-arrow-toggle') : null;

        if (!trigger || !panel || !icon) return;

        trigger.classList.add('open');
        panel.classList.add('open');
        icon.classList.add('rotated');
        if (btn) btn.setAttribute('aria-expanded', 'true');
    }

    function cerrarSemestre(key) {
        var trigger = document.getElementById('trigger-' + key);
        var panel   = document.getElementById('panel-' + key);
        var icon    = document.getElementById('icon-' + key);
        var btn     = trigger ? trigger.querySelector('.barra-arrow-toggle') : null;

        if (!trigger || !panel || !icon) return;

        trigger.classList.remove('open');
        panel.classList.remove('open');
        icon.classList.remove('rotated');
        if (btn) btn.setAttribute('aria-expanded', 'false');
    }

    function toggleSemestre(key) {
        var panel = document.getElementById('panel-' + key);
        if (!panel) return;

        var estaAbierto = panel.classList.contains('open');

        // Cerrar todos primero (acordeón exclusivo)
        Object.keys(semestres).forEach(function (k) { cerrarSemestre(k); });

        // Si estaba cerrado, abrir el clickeado
        if (!estaAbierto) { abrirSemestre(key); }
    }

    // Registrar clicks en cada botón de flecha
    Object.keys(semestres).forEach(function (key) {
        var trigger = document.getElementById('trigger-' + key);
        if (!trigger) return;

        var btn = trigger.querySelector('.barra-arrow-toggle');
        if (btn) {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                toggleSemestre(key);
            });
        }
    });

    // Auto-expandir el semestre de la página activa
    var path = window.location.pathname;
    Object.keys(semestres).forEach(function (key) {
        var activo = semestres[key].some(function (ruta) {
            return path.includes(ruta);
        });
        if (activo) { abrirSemestre(key); }
    });

    // Toggle del sidebar desde el botón hamburguesa (menuToggle)
    var menuToggle = document.getElementById('menuToggle');
    var sidebar    = document.getElementById('sidebar');

    if (menuToggle && sidebar) {
        menuToggle.addEventListener('click', function () {
            sidebar.classList.toggle('collapsed');
        });
    }
})();
</script>
