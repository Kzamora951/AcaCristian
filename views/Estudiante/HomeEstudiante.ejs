<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Universidad Pedagógica - Estudiante</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/stylesheets/estudiante/estudiante.css">
    <script src="/javascripts/estudiante.js"></script>
</head>

<body>
    <div class="app-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="logo">
                <h2><i class="fas fa-graduation-cap"></i> UPN</h2>
            </div>

            <div class="welcome-section">
                <h3>Bienvenido Estudiante</h3>
                <p>Universidad Pedagógica Nacional</p>
                <div class="user-role">
                    <span class="badge bg-info">Estudiante</span>
                </div>
            </div>

            <nav class="nav-menu">
                <a href="/Estudiante/HomeEstudiante" class="nav-item active">
                    <i class="fas fa-home"></i>
                    <span>Inicio</span>
                </a>
            </nav>

            <div class="logout-btn">
                <a href="/logout">
                    <i class="fas fa-sign-out-alt"></i>
                    <span> Cerrar Sesión</span>
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <div class="container-fluid py-5">
                <div class="row justify-content-center">
                    <div class="col-12 text-center mb-5">
                        <h1 class="main-title">Diseño al alcance</h1>
                        <p class="lead text-muted">Selecciona tu semestre para continuar</p>
                    </div>
                </div>
                
                <div class="row justify-content-center g-4">
                    <div class="col-md-4 col-sm-6">
                        <div class="semester-card">
                            <div class="card-body text-center">
                                <div class="semester-icon">
                                    <i class="fas fa-book-open"></i>
                                </div>
                                <h3 class="semester-title">Primer Semestre</h3>
                                <p class="semester-description">Inicia tu camino en la universidad</p>
                                <button class="btn btn-primary semester-btn" onclick="goToSemester('primer')">
                                    Ingresar
                                </button>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-md-4 col-sm-6">
                        <div class="semester-card">
                            <div class="card-body text-center">
                                <div class="semester-icon">
                                    <i class="fas fa-book-reader"></i>
                                </div>
                                <h3 class="semester-title">Segundo Semestre</h3>
                                <p class="semester-description">Continúa tu formación académica</p>
                                <button class="btn btn-primary semester-btn" onclick="goToSemester('segundo')">
                                    Ingresar
                                </button>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-md-4 col-sm-6">
                        <div class="semester-card">
                            <div class="card-body text-center">
                                <div class="semester-icon">
                                    <i class="fas fa-graduation-cap"></i>
                                </div>
                                <h3 class="semester-title">Tercer Semestre</h3>
                                <p class="semester-description">Avanza en tu carrera profesional</p>
                                <button class="btn btn-primary semester-btn" onclick="goToSemester('tercer')">
                                    Ingresar
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        function goToSemester(semestre) {
            window.location.href = "/Estudiante/" + semestre+"semestre";
        }
    </script>
</body>
</html>