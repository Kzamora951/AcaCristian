<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tercer Semestre - Universidad Pedagógica</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/stylesheets/tercersemestre.css">
</head>

<body>
    <!-- Top Navigation -->
    <nav class="top-nav">
        <div class="nav-container">
            <div class="nav-left">
                <button class="menu-toggle" id="menuToggle">
                    <i class="fas fa-bars"></i>
                </button>
                <div class="nav-brand">
                    <i class="fas fa-graduation-cap"></i>
                    <span>UPN</span>
                </div>
            </div>
            <div class="nav-center">
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Buscar en el repositorio (ej: 'Digital', 'Multimedia')..." class="search-input">
                </div>
            </div>
            <div class="nav-right">
                <div class="user-info">
                    <span class="user-name"><%= user ? user.nombre : 'Estudiante' %></span>
                    <div class="user-avatar">
                        <i class="fas fa-user"></i>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <div class="main-container">
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <h3>LÍNEA DE DISEÑO</h3>
            </div>
            <nav class="semester-nav">
                <div class="semester-group">
                    <h4 class="semester-title">SEMESTRE 1</h4>
                    <ul class="subject-list">
                        <li class="subject-item">
                            <a href="/Estudiante/primersemestre">
                                <i class="fas fa-palette"></i>
                                <span>Fundamentos de Diseño</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                        <li class="subject-item">
                            <a href="/Estudiante/primersemestre">
                                <i class="fas fa-shapes"></i>
                                <span>Geometría</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                        <li class="subject-item">
                            <a href="/Estudiante/primersemestre">
                                <i class="fas fa-pencil-ruler"></i>
                                <span>Dibujo Técnico</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </div>
                <div class="semester-group">
                    <h4 class="semester-title">SEMESTRE 2</h4>
                    <ul class="subject-list">
                        <li class="subject-item">
                            <a href="/Estudiante/segundosemestre">
                                <i class="fas fa-brain"></i>
                                <span>Teoría y Métodos</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                        <li class="subject-item">
                            <a href="/Estudiante/segundosemestre">
                                <i class="fas fa-cube"></i>
                                <span>Diseño Tridimensional</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                        <li class="subject-item">
                            <a href="/Estudiante/segundosemestre">
                                <i class="fas fa-paint-brush"></i>
                                <span>Teoría del Color</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </div>
                <div class="semester-group">
                    <h4 class="semester-title">SEMESTRE 3</h4>
                    <ul class="subject-list">
                        <li class="subject-item active">
                            <a href="/Estudiante/tercersemestre">
                                <i class="fas fa-laptop-code"></i>
                                <span>Diseño Digital</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                        <li class="subject-item">
                            <a href="/Estudiante/tercersemestre">
                                <i class="fas fa-camera"></i>
                                <span>Fotografía</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                        <li class="subject-item">
                            <a href="/Estudiante/tercersemestre">
                                <i class="fas fa-video"></i>
                                <span>Producción Audiovisual</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>
            <div class="sidebar-footer">
                <a href="/Estudiante/HomeEstudiante" class="back-btn">
                    <i class="fas fa-arrow-left"></i>
                    <span>Volver al Inicio</span>
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <div class="content-wrapper">
                <!-- Subject Header -->
                <header class="subject-header">
                    <div class="subject-info">
                        <div class="subject-badge">SEMESTRE 3 Aplicación Digital</div>
                        <h1 class="subject-title">Diseño Digital</h1>
                        <p class="subject-description">
                            Integración de tecnologías digitales y herramientas multimedia para el desarrollo de proyectos de diseño contemporáneo.
                        </p>
                    </div>
                    <div class="subject-actions">
                        <button class="action-btn primary">
                            <i class="fas fa-play"></i>
                            <span>Continuar Curso</span>
                        </button>
                    </div>
                </header>

                <!-- Thematic Cores -->
                <section class="thematic-cores">
                    <h2 class="section-title">NÚCLEOS TEMÁTICOS</h2>
                    <div class="cores-grid">
                        <div class="core-card">
                            <div class="core-icon">
                                <i class="fas fa-desktop"></i>
                            </div>
                            <h3 class="core-title">Interfaces Digitales</h3>
                            <p class="core-description">
                                Diseño y desarrollo de interfaces de usuario aplicando principios de UX/UI y usabilidad digital.
                            </p>
                            <div class="core-progress">
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 70%"></div>
                                </div>
                                <span class="progress-text">70% completado</span>
                            </div>
                        </div>

                        <div class="core-card">
                            <div class="core-icon">
                                <i class="fas fa-vector-square"></i>
                            </div>
                            <h3 class="core-title">Gráficos Vectoriales</h3>
                            <p class="core-description">
                                Creación y manipulación de gráficos vectoriales mediante herramientas digitales especializadas.
                            </p>
                            <div class="core-progress">
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 85%"></div>
                                </div>
                                <span class="progress-text">85% completado</span>
                            </div>
                        </div>

                        <div class="core-card">
                            <div class="core-icon">
                                <i class="fas fa-code"></i>
                            </div>
                            <h3 class="core-title">Desarrollo Web</h3>
                            <p class="core-description">
                                Fundamentos de desarrollo web aplicados al diseño y creación de experiencias digitales interactivas.
                            </p>
                            <div class="core-progress">
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 55%"></div>
                                </div>
                                <span class="progress-text">55% completado</span>
                            </div>
                        </div>

                        <div class="core-card">
                            <div class="core-icon">
                                <i class="fas fa-mobile-alt"></i>
                            </div>
                            <h3 class="core-title">Diseño Móvil</h3>
                            <p class="core-description">
                                Principios y técnicas de diseño adaptado para dispositivos móviles y aplicaciones interactivas.
                            </p>
                            <div class="core-progress">
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 40%"></div>
                                </div>
                                <span class="progress-text">40% completado</span>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Upcoming Deliveries -->
                <section class="upcoming-deliveries">
                    <h2 class="section-title">PRÓXIMAS ENTREGAS</h2>
                    <div class="deliveries-list">
                        <div class="delivery-card urgent">
                            <div class="delivery-icon">
                                <i class="fas fa-clock"></i>
                            </div>
                            <div class="delivery-content">
                                <h4 class="delivery-title">Prototipo de App Móvil</h4>
                                <p class="delivery-details">
                                    Diseño UX/UI • 11:59 PM
                                </p>
                                <div class="delivery-date">
                                    <span class="date-label">OCT</span>
                                    <span class="date-number">26</span>
                                </div>
                            </div>
                            <button class="delivery-btn">
                                Ver detalles
                            </button>
                        </div>

                        <div class="delivery-card">
                            <div class="delivery-icon">
                                <i class="fas fa-file-code"></i>
                            </div>
                            <div class="delivery-content">
                                <h4 class="delivery-title">Portfolio Digital</h4>
                                <p class="delivery-details">
                                    Sitio web personal • 11:59 PM
                                </p>
                                <div class="delivery-date">
                                    <span class="date-label">NOV</span>
                                    <span class="date-number">02</span>
                                </div>
                            </div>
                            <button class="delivery-btn">
                                Ver detalles
                            </button>
                        </div>

                        <div class="delivery-card">
                            <div class="delivery-icon">
                                <i class="fas fa-palette"></i>
                            </div>
                            <div class="delivery-content">
                                <h4 class="delivery-title">Sistema de Identidad Visual</h4>
                                <p class="delivery-details">
                                    Branding digital • 11:59 PM
                                </p>
                                <div class="delivery-date">
                                    <span class="date-label">NOV</span>
                                    <span class="date-number">08</span>
                                </div>
                            </div>
                            <button class="delivery-btn">
                                Ver detalles
                            </button>
                        </div>
                    </div>
                </section>
            </div>
        </main>
    </div>

    <script>
        // Toggle sidebar
        document.getElementById('menuToggle').addEventListener('click', function() {
            document.getElementById('sidebar').classList.toggle('collapsed');
        });

        // Search functionality
        document.querySelector('.search-input').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                const searchTerm = e.target.value;
                console.log('Buscando:', searchTerm);
                // Implementar lógica de búsqueda
            }
        });
    </script>
</body>
</html>
