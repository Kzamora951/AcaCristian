                    GLOSARIO · CONCEPTOS CLAVE DE D'ARCY THOMPSON
                    <span class="section-label__hint">Haz clic en cada ficha para ver el video explicativo</span>
                </div>

                <div class="glosario-card">
                    <div class="glosario-grid">

                        <div class="glosario-item" onclick="toggleGlosario(this)">
                            <div class="glosario-item__icon">⚡</div>
                            <p class="glosario-item__name">Tensión Superficial</p>
                            <p class="glosario-item__cta">▶ clic para video</p>
                            <div class="glosario-item__video hidden">
                                <video controls><source src="#" type="video/mp4"></video>
                            </div>
                        </div>

                        <div class="glosario-item" onclick="toggleGlosario(this)">
                            <div class="glosario-item__icon">🏗️</div>
                            <p class="glosario-item__name">Eficiencia Estructural</p>
                            <p class="glosario-item__cta">▶ clic para video</p>
                            <div class="glosario-item__video hidden">
                                <video controls><source src="#" type="video/mp4"></video>
                            </div>
                        </div>

                        <div class="glosario-item" onclick="toggleGlosario(this)">
                            <div class="glosario-item__icon">📐</div>
                            <p class="glosario-item__name">Teoría de Transformaciones</p>
                            <p class="glosario-item__cta">▶ clic para video</p>
                            <div class="glosario-item__video hidden">
                                <video controls><source src="#" type="video/mp4"></video>
                            </div>
                        </div>

                        <div class="glosario-item" onclick="toggleGlosario(this)">
