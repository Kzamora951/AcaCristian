<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Segundo Semestre - Universidad Pedagógica</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/stylesheets/segundosemestre.css">
</head>

<body>
    <!-- Top Navigation -->
    <nav class="top-nav">
        <div class="nav-container">
            <div class="nav-left">
                <button class="menu-toggle" id="menuToggle">
                    <i class="fas fa-bars"></i>
                </button>
                <div class="nav-brand">
                    <i class="fas fa-graduation-cap"></i>
                    <span>UPN</span>
                </div>
            </div>
            <div class="nav-center">
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Buscar en el repositorio (ej: 'Epistemología', 'Metodología')..." class="search-input">
                </div>
            </div>
            <div class="nav-right">
                <div class="user-info">
                    <span class="user-name"><%= user ? user.nombre : 'Estudiante' %></span>
                    <div class="user-avatar">
                        <i class="fas fa-user"></i>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <div class="main-container">
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <h3>LÍNEA DE DISEÑO</h3>
            </div>
            <nav class="semester-nav">
                <div class="semester-group">
                    <h4 class="semester-title">SEMESTRE 1</h4>
                    <ul class="subject-list">
                        <li class="subject-item">
                            <a href="/Estudiante/primersemestre">
                                <i class="fas fa-palette"></i>
                                <span>1. Fundamentos de Diseño</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                        <li class="subject-item">
                            <a href="/Estudiante/primersemestre">
                                <i class="fas fa-shapes"></i>
                                <span>1.1 Gramática Visual y Composición</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                        <li class="subject-item">
                            <a href="/Estudiante/primersemestre">
                                <i class="fas fa-pencil-ruler"></i>
                                <span>1.2 Principios de Diseño Bidimensional e Tridimensional</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                        <li class="subject-item">
                            <a href="/Estudiante/primersemestre">
                                <i class="fas fa-pencil-ruler"></i>
                                <span>1.3 Principios Universales de Diseño</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                        <li class="subject-item">
                            <a href="/Estudiante/primersemestre">
                                <i class="fas fa-pencil-ruler"></i>
                                <span>1.4 La Naturaleza de los Objetos</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </div>
                <div class="semester-group">
                    <h4 class="semester-title">SEMESTRE 2</h4>
                    <ul class="subject-list">
                        <li class="subject-item active">
                            <a href="/Estudiante/segundosemestre">
                                <i class="fas fa-brain"></i>
                                <span>2. Teoría y Métodos</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                        <li class="subject-item">
                            <a href="/Estudiante/segundosemestre">
                                <i class="fas fa-cube"></i>
                                <span>2.1 Epistemología y Evolución del Diseño</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                        <li class="subject-item">
                            <a href="/Estudiante/segundosemestre">
                                <i class="fas fa-paint-brush"></i>
                                <span>2.2 El Pensamiento de Diseño (Design Thinking)</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                        <li class="subject-item">
                            <a href="/Estudiante/segundosemestre">
                                <i class="fas fa-cube"></i>
                                <span>2.3 Historia e Impacto Social</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </div>
                <div class="semester-group">
                    <h4 class="semester-title">SEMESTRE 3</h4>
                    <ul class="subject-list">
                        <li class="subject-item">
                            <a href="/Estudiante/tercersemestre">
                                <i class="fas fa-laptop-code"></i>
                                <span>Diseño y Bionica</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                        <li class="subject-item">
                            <a href="/Estudiante/tercersemestre">
                                <i class="fas fa-camera"></i>
                                <span>Fotografía</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>
            <div class="sidebar-footer">
                <a href="/Estudiante/HomeEstudiante" class="back-btn">
                    <i class="fas fa-arrow-left"></i>
                    <span>Volver al Inicio</span>
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <div class="content-wrapper">
                <!-- Subject Header -->
                <header class="subject-header">
                    <div class="subject-info">
                        <div class="subject-badge">SEMESTRE 2 Epistemología</div>
                        <h1 class="subject-title">Teoría y Métodos de Diseño</h1>
                        <p class="subject-description">
                            Análisis crítico de las teorías del diseño y metodologías de investigación aplicadas al proceso proyectual contemporáneo.
                        </p>
                    </div>
                    <div class="subject-actions">
                        <button class="action-btn primary">
                            <i class="fas fa-play"></i>
                            <span>Continuar Curso</span>
                        </button>
                    </div>
                </header>

                <!-- Thematic Cores -->
                <section class="thematic-cores">
                    <h2 class="section-title">NÚCLEOS TEMÁTICOS</h2>
                    <div class="cores-grid">
                        <div class="core-card">
                            <div class="core-icon">
                                <i class="fas fa-lightbulb"></i>
                            </div>
                            <h3 class="core-title">Lógicas de Pensamiento</h3>
                            <p class="core-description">
                                Estudio de los procesos cognitivos y sistemas de razonamiento aplicados al diseño conceptual y metodológico.
                            </p>
                            <div class="core-progress">
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 65%"></div>
                                </div>
                                <span class="progress-text">65% completado</span>
                            </div>
                        </div>

                        <div class="core-card">
                            <div class="core-icon">
                                <i class="fas fa-history"></i>
                            </div>
                            <h3 class="core-title">Historia y Tendencias</h3>
                            <p class="core-description">
                                Análisis histórico del diseño y exploración de tendencias emergentes en la práctica contemporánea.
                            </p>
                            <div class="core-progress">
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 80%"></div>
                                </div>
                                <span class="progress-text">80% completado</span>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Upcoming Deliveries -->
                <section class="upcoming-deliveries">
                    <h2 class="section-title">PRÓXIMAS ENTREGAS</h2>
                    <div class="deliveries-list">
                        <div class="delivery-card urgent">
                            <div class="delivery-icon">
                                <i class="fas fa-clock"></i>
                            </div>
                            <div class="delivery-content">
                                <h4 class="delivery-title">Ensayo Crítico de Diseño</h4>
                                <p class="delivery-details">
                                    Análisis teórico • 11:59 PM
                                </p>
                                <div class="delivery-date">
                                    <span class="date-label">OCT</span>
                                    <span class="date-number">25</span>
                                </div>
                            </div>
                            <button class="delivery-btn">
                                Ver detalles
                            </button>
                        </div>

                        <div class="delivery-card">
                            <div class="delivery-icon">
                                <i class="fas fa-project-diagram"></i>
                            </div>
                            <div class="delivery-content">
                                <h4 class="delivery-title">Mapa Conceptual de Metodologías</h4>
                                <p class="delivery-details">
                                    Trabajo grupal • 11:59 PM
                                </p>
                                <div class="delivery-date">
                                    <span class="date-label">OCT</span>
                                    <span class="date-number">30</span>
                                </div>
                            </div>
                            <button class="delivery-btn">
                                Ver detalles
                            </button>
                        </div>
                    </div>
                </section>
            </div>
        </main>
    </div>

    <script>
        // Toggle sidebar
        document.getElementById('menuToggle').addEventListener('click', function() {
            document.getElementById('sidebar').classList.toggle('collapsed');
        });

        // Search functionality
        document.querySelector('.search-input').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                const searchTerm = e.target.value;
                console.log('Buscando:', searchTerm);
                // Implementar lógica de búsqueda
            }
        });
    </script>
</body>
</html>
