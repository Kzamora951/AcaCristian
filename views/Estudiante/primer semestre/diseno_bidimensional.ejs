<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>1.2 Principios de Diseño Bidimensional y Tridimensional - Universidad Pedagógica</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/stylesheets/estudiante/subtemas/diseno_bidimensional.css">
    <style>
        /* Estilo para tema activo en barra lateral */
        .subject-item a[href="/Estudiante/diseno_bidimensional"] {
            background-color: #4a60c0 !important;
            color: white !important;
            border-radius: 8px;
            padding: 10px 15px;
            margin: 2px 0;
        }
        
        .subject-item a[href="/Estudiante/diseno_bidimensional"]:hover {
            background-color: #3a4e9a !important;
            color: white !important;
        }
    </style>
</head>

<body>
    <!-- ══════════════════════ TOP NAV ══════════════════════ -->
  <nav class="top-nav">
    <div class="nav-container">
      <div class="nav-left">
        <button class="menu-toggle" id="menuToggle">
          <i class="fas fa-bars"></i>
        </button>
        <div class="nav-brand">
          <i class="fas fa-graduation-cap"></i>
          <span>UPN</span>
        </div>
      </div>
      <div class="nav-center">
        <div class="search-box">
          <i class="fas fa-search"></i>
          <input type="text" placeholder="Buscar en el repositorio (ej: 'Módulos', 'Gradación', 'Volumen')..." class="search-input">
        </div>
      </div>
      <div class="nav-right">
        <div class="user-info">
          <span class="user-name">Bienvenido Estudiante</span>
          <div class="user-avatar"><i class="fas fa-user"></i></div>
        </div>
      </div>
    </div>
  </nav>

  <div class="main-container">

    <%- include('../../barraLateral/barra') %>

    <!-- ══════════════════════ MAIN CONTENT ══════════════════════ -->
    <main class="main-content">
    <div class="page-wrapper">

      <!-- Navegación de anclaje -->
      <nav class="anchor-nav" id="anchor-nav">
        <a href="#resumen"   class="active">Resumen</a>
        <a href="#conceptos">Conceptos clave</a>
        <a href="#practica" >Aplicación práctica</a>
        <a href="#docente"  >Conexión docente</a>
      </nav>

      <!-- ─────────────────────────────────────────
           SECCIÓN 1 · RESUMEN
      ───────────────────────────────────────── -->
      <section class="section-block" id="resumen">

        <div class="section-heading">
          <div class="section-acento"></div>
          <span class="section-label">Resumen del tema</span>
        </div>

        <!-- Hero card -->
        <div class="upn-card">
          <div class="hero-grid">
            <div>
              <p class="hero-eyebrow">Fundamentos de Diseño · Wucius Wong — Fundamentos del Diseño</p>
              <h1 class="hero-title">La Evolución<br>de la Forma</h1>
              <p class="hero-desc">
                Wucius Wong establece un sistema lógico para entender el diseño desde su unidad mínima
                hasta la complejidad del espacio. El concepto central es la <em>conceptualización de
                la forma</em>: cómo elementos invisibles (puntos y líneas) se vuelven tangibles al
                convertirse en planos y, finalmente, en volúmenes tridimensionales. Para el diseñador
                tecnológico, Wong es la guía para dejar de diseñar "cosas aisladas" y empezar a
                diseñar sistemas estructurados y familias de objetos.
              </p>
              <div class="hero-actions">
                <a href="#" class="btn-upn"><i class="fas fa-play"></i> Ver introducción</a>
                <a href="#" class="btn-link-upn"><i class="fas fa-book-open"></i> Leer en Scribd</a>
              </div>
            </div>
            <div>
              <video class="video-box" controls style="max-width: 100%; width: 100%; height: auto; max-height: 400px;">
                <source src="/videos/PRINCIPIOS.mp4" type="video/mp4">
                Tu navegador no soporta el elemento de video.
              </video>
              <p class="video-caption">Introducción al tema · Principios Universales</p>
            </div>
          </div>
        </div>

        <!-- Diagrama Del Punto al Volumen -->
        <div class="upn-card">
          <div class="section-heading" style="margin-bottom: 20px;">
            <div class="section-acento"></div>
            <span class="section-label">Del punto al volumen</span>
          </div>
          <div class="dimension-flow">
            <div class="dim-step">
              <div class="dim-shape"><div class="dim-dot"></div></div>
              <div class="dim-label">Punto</div>
              <div class="dim-sub">Indica posición. Sin dimensión real.</div>
            </div>
            <div class="dim-arrow">→</div>
            <div class="dim-step">
              <div class="dim-shape"><div class="dim-line"></div></div>
              <div class="dim-label">Línea</div>
              <div class="dim-sub">Rastro del punto en movimiento. Da dirección.</div>
            </div>
            <div class="dim-arrow">→</div>
            <div class="dim-step">
              <div class="dim-shape"><div class="dim-plane"></div></div>
              <div class="dim-label">Plano</div>
              <div class="dim-sub">Recorrido de la línea. Define límites.</div>
            </div>
            <div class="dim-arrow">→</div>
            <div class="dim-step">
              <div class="dim-shape"><div class="dim-cube"></div></div>
              <div class="dim-label">Volumen</div>
              <div class="dim-sub">Recorrido del plano. Ocupa espacio.</div>
            </div>
          </div>
        </div>

        <!-- Sub-tarjetas -->
        <div class="two-col">
          <div class="sub-card">
            <div class="sub-card-header">
              <div class="step-badge">1</div>
              <h3>Módulos y Supermódulos</h3>
            </div>
            <p>Unidades pequeñas (módulos) que al agruparse crean estructuras más complejas. La base del diseño sistémico y los objetos escalables o desarmables.</p>
            <div class="video-sm"><div class="play-sm"><div class="play-sm-icon"></div></div></div>
          </div>
          <div class="sub-card">
            <div class="sub-card-header">
              <div class="step-badge">2</div>
              <h3>Repetición y Gradación</h3>
            </div>
            <p>La repetición genera orden. La gradación —cambio gradual de tamaño o forma— crea dinamismo e ilusión de profundidad en el objeto diseñado.</p>
            <div class="video-sm"><div class="play-sm"><div class="play-sm-icon"></div></div></div>
          </div>
        </div>

      </section>

      <!-- ─────────────────────────────────────────
           SECCIÓN 2 · CONCEPTOS CLAVE
      ───────────────────────────────────────── -->
      <section class="section-block" id="conceptos">

        <div class="section-heading">
          <div class="section-acento"></div>
          <span class="section-label">Conceptos clave · Elementos de relación y composición</span>
          <span class="section-hint">Haz clic en cada ficha para ver el video explicativo</span>
        </div>

        <!-- Flip cards -->
        <div class="upn-card">
          <div class="cards-grid" id="cards-grid"></div>
        </div>

        <!-- Videos 2D y 3D -->
        <div class="two-col">
          <div class="sub-card">
            <div class="sub-card-header">
              <div class="step-badge">2D</div>
              <h3>Diseño Bidimensional</h3>
            </div>
            <p>Exploración de planos, superficies y composición en el espacio gráfico. Fundamento para la comunicación visual y el diseño gráfico aplicado.</p>
            <div class="video-sm"><div class="play-sm"><div class="play-sm-icon"></div></div></div>
          </div>
          <div class="sub-card">
            <div class="sub-card-header">
              <div class="step-badge">3D</div>
              <h3>Diseño Tridimensional</h3>
            </div>
            <p>Construcción de volúmenes y estructuras espaciales. Base conceptual para el modelado CAD con AutoCad y SolidWorks en los talleres de la Licenciatura.</p>
            <div class="video-sm"><div class="play-sm"><div class="play-sm-icon"></div></div></div>
          </div>
        </div>

      </section>

      <!-- ─────────────────────────────────────────
           SECCIÓN 3 · APLICACIÓN PRÁCTICA
      ───────────────────────────────────────── -->
      <section class="section-block" id="practica">

        <div class="section-heading">
          <div class="section-acento"></div>
          <span class="section-label">Aplicación práctica · Maquetas y estructuras espaciales</span>
        </div>

        <div class="upn-card">
          <h2>¿Cómo se aplica en la Licenciatura?</h2>
          <p>
            Premisa: creación de maquetas conceptuales y estructuras espaciales a partir de formas
            básicas. En los ejercicios de taller —especialmente en el "Cubo de Diseño" o estructuras
            modulares— el estudiante debe demostrar que puede controlar el espacio.
          </p>
          <div class="highlight-upn">
            <p>
              Al sustentar una maqueta ante el docente Ricardo, el estudiante no dice
              <em>"puse esto aquí porque se ve bien"</em>, sino:
              <strong>"Apliqué una anomalía en la estructura para señalar el punto de
              interacción del usuario."</strong>
            </p>
          </div>
          <p>
            Los principios de Wong son también el <strong>algoritmo mental</strong> detrás del
            modelado CAD: entender cómo un plano se convierte en volumen es la base para usar
            software como AutoCad o SolidWorks. Aplicar el concepto de módulos permite diseñar
            objetos <strong>escalables o desarmables</strong> (diseño sistémico).
          </p>
        </div>

        <div class="two-col">
          <div class="sub-card">
            <div class="sub-card-header">
              <div class="step-badge"><i class="fas fa-play" style="font-size:9px"></i></div>
              <h3>Cubo de Diseño: ejercicio modular</h3>
            </div>
            <p>Demostración del ejercicio clásico de taller aplicando los principios de módulo y supermódulo en una estructura física.</p>
            <div class="video-sm"><div class="play-sm"><div class="play-sm-icon"></div></div></div>
          </div>
          <div class="sub-card">
            <div class="sub-card-header">
              <div class="step-badge"><i class="fas fa-play" style="font-size:9px"></i></div>
              <h3>De Wong al modelo CAD</h3>
            </div>
            <p>Cómo los conceptos de Wong se traducen directamente al modelado 3D en software técnico como AutoCad y SolidWorks.</p>
            <div class="video-sm"><div class="play-sm"><div class="play-sm-icon"></div></div></div>
          </div>
        </div>

      </section>

      <!-- ─────────────────────────────────────────
           SECCIÓN 4 · CONEXIÓN DOCENTE
      ───────────────────────────────────────── -->
      <section class="section-block" id="docente">

        <div class="section-heading">
          <div class="section-acento"></div>
          <span class="section-label">Conexión con la práctica docente · Perfil LDT</span>
        </div>

        <div class="upn-card">
          <h2>Wong como herramienta pedagógica</h2>
          <p>
            Wucius Wong es una herramienta pedagógica poderosa para la enseñanza de la tecnología
            en bachillerato. Permite a los docentes explicar temas de geometría descriptiva, dibujo
            técnico y estructuras de forma creativa, pasando de la abstracción matemática a la
            construcción de objetos reales que los estudiantes pueden tocar y ensamblar.
          </p>
          <p>
            El Licenciado en Diseño Tecnológico puede usar los principios de Wong para conectar
            la geometría descriptiva del currículo con la fabricación de objetos reales en el aula
            taller, haciendo tangible lo que los estudiantes aprenden en matemáticas y física.
          </p>
        </div>

        <div class="two-col">
          <div class="sub-card">
            <div class="sub-card-header">
              <div class="step-badge"><i class="fas fa-play" style="font-size:9px"></i></div>
              <h3>Geometría descriptiva con módulos</h3>
            </div>
            <p>Cómo usar los ejercicios modulares de Wong para enseñar geometría de forma práctica y visual en el aula de tecnología.</p>
            <div class="video-sm"><div class="play-sm"><div class="play-sm-icon"></div></div></div>
          </div>
          <div class="sub-card">
            <div class="sub-card-header">
              <div class="step-badge"><i class="fas fa-play" style="font-size:9px"></i></div>
              <h3>Diseño sistémico en el aula</h3>
            </div>
            <p>Actividades de taller para que los estudiantes de bachillerato diseñen y construyan objetos desarmables con principios de Wong.</p>
            <div class="video-sm"><div class="play-sm"><div class="play-sm-icon"></div></div></div>
          </div>
        </div>

      </section>

    </div></div>main>
  </div><!-- /main-container -->

    
    // ── Flip cards ───────────────────────────────────────────
    var concepts = [
      { label: 'Del Punto al Volumen',    icon: '◆'  },
      { label: 'Módulos',                 icon: '⊞'  },
      { label: 'Supermódulos',            icon: '⊟'  },
      { label: 'Repetición',              icon: '≡'  },
      { label: 'Gradación',               icon: '▲'  },
      { label: 'Anomalía',                icon: '✦'  },
      { label: 'Radiación',               icon: '✳'  },
      { label: 'Superposición',           icon: '⧉'  },
    ];

    // 8 tarjetas → 8 columnas
    var grid = document.getElementById('cards-grid');
    grid.style.gridTemplateColumns = 'repeat(8, 1fr)';

    concepts.forEach(function (item) {
      var card = document.createElement('div');
      card.className = 'flip-card';
      card.innerHTML =
        '<div class="flip-inner">' +
          '<div class="flip-front">' +
            '<div class="flip-icon-wrap">' + item.icon + '</div>' +
            '<div class="flip-label">'     + item.label + '</div>' +
            '<div class="flip-hint">▸ clic para video</div>' +
          '</div>' +
          '<div class="flip-back">' +
            '<div class="flip-back-play"><div class="back-play-icon"></div></div>' +
            '<div class="flip-back-label">' + item.label + '</div>' +
          '</div>' +
        '</div>';
      card.addEventListener('click', function () { card.classList.toggle('flipped'); });
      grid.appendChild(card);
    });

    // ── Highlight active anchor on scroll ───────────────────
    var sections = document.querySelectorAll('.section-block');
    var navLinks = document.querySelectorAll('.anchor-nav a');

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          navLinks.forEach(function (l) { l.classList.remove('active'); });
          var active = document.querySelector('.anchor-nav a[href="#' + entry.target.id + '"]');
          if (active) active.classList.add('active');
        }
      });
    }, { rootMargin: '-120px 0px -60% 0px' });

    sections.forEach(function (s) { observer.observe(s); });

    // ── Search ───────────────────────────────────────────────
    document.querySelector('.search-input').addEventListener('keypress', function (e) {
      if (e.key === 'Enter') console.log('Buscando:', e.target.value);
    });
  </script>

</body>
</html>
