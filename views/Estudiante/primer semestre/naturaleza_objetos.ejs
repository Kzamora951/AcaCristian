<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>1.4 La Naturaleza de los Objetos - Universidad Pedagógica</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/stylesheets/estudiante/subtemas/naturaleza_objetos.css">
    <style>
        /* Estilo para tema activo en barra lateral */
        .subject-item a[href="/Estudiante/naturaleza_objetos"] {
            background-color: #4a60c0 !important;
            color: white !important;
            border-radius: 8px;
            padding: 10px 15px;
            margin: 2px 0;
        }
        
        .subject-item a[href="/Estudiante/naturaleza_objetos"]:hover {
            background-color: #3a4e9a !important;
            color: white !important;
        }
    </style>
</head>

<body>
    <!-- Top Navigation -->
    <nav class="top-nav">
        <div class="nav-container">
            <div class="nav-left">
                <button class="menu-toggle" id="menuToggle">
                    <i class="fas fa-bars"></i>
                </button>
                <div class="nav-brand">
                    <i class="fas fa-graduation-cap"></i>
                    <span>UPN</span>
                </div>
            </div>
            <div class="nav-center">
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Buscar en el repositorio (ej: 'Biomímesis', 'Deductivo')..." class="search-input">
                </div>
            </div>
            <div class="nav-right">
                <div class="user-info">
                    <span class="user-name">Bienvenido Estudiante</span>
                    <div class="user-avatar">
                        <i class="fas fa-user"></i>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <div class="main-container">
        <%- include('../../barraLateral/barra') %>

        <!-- Main Content -->
        <main class="main-content">
        <div class="page-wrapper">
        <!-- -->
        
    <script>
    // ── Sidebar toggle ──────────────────────────────────────
    document.getElementById('menuToggle').addEventListener('click', function () {
      document.getElementById('sidebar').classList.toggle('collapsed');
    });

    // ── Expandir subtemas de semestre 1 al cargar ───────────
    document.addEventListener('DOMContentLoaded', function () {
      const subjects = document.getElementById('fundamentos-subjects');
      const icon     = document.getElementById('fundamentos-icon');
      if (subjects && icon) {
        subjects.classList.add('show');
        icon.classList.add('rotated');
      }
    });

    // ── Toggle accordions del sidebar ──────────────────────
    ['fundamentos', 'teoria', 'diseno'].forEach(function (key) {
      document.getElementById(key + '-toggle').addEventListener('click', function () {
        const list = document.getElementById(key + '-subjects');
        const icon = document.getElementById(key + '-icon');
        list.classList.toggle('show');
        icon.classList.toggle('rotated');
      });
    });

    // ── Flip cards ──────────────────────────────────────────
    const concepts = [
      { label: 'Navaja de Ockham',           icon: '✂️' },
      { label: 'Usabilidad Estética',         icon: '✦'  },
      { label: 'Jerarquía',                   icon: '◈'  },
      { label: 'Ley de Fitts',                icon: '⊙'  },
      { label: 'Asequibilidad',               icon: '✋' },
      { label: 'Señal-Ruido',                 icon: '≈'  },
    ];

    const grid = document.getElementById('cards-grid');
    concepts.forEach(function (item) {
      const card = document.createElement('div');
      card.className = 'flip-card';
      card.innerHTML =
        '<div class="flip-inner">' +
          '<div class="flip-front">' +
            '<div class="flip-icon-wrap">' + item.icon + '</div>' +
            '<div class="flip-label">'     + item.label + '</div>' +
            '<div class="flip-hint">▸ clic para video</div>' +
          '</div>' +
          '<div class="flip-back">' +
            '<div class="flip-back-play"><div class="back-play-icon"></div></div>' +
            '<div class="flip-back-label">' + item.label + '</div>' +
          '</div>' +
        '</div>';
      card.addEventListener('click', function () { card.classList.toggle('flipped'); });
      grid.appendChild(card);
    });

    // ── Highlight active anchor on scroll ──────────────────
    const sections = document.querySelectorAll('.section-block');
    const navLinks = document.querySelectorAll('.anchor-nav a');

    const observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          navLinks.forEach(function (l) { l.classList.remove('active'); });
          var active = document.querySelector('.anchor-nav a[href="#' + entry.target.id + '"]');
          if (active) active.classList.add('active');
        }
      });
    }, { rootMargin: '-120px 0px -60% 0px' });

    sections.forEach(function (s) { observer.observe(s); });

    // ── Search ──────────────────────────────────────────────
    document.querySelector('.search-input').addEventListener('keypress', function (e) {
      if (e.key === 'Enter') console.log('Buscando:', e.target.value);
    });
  </script>

</body>
</html>