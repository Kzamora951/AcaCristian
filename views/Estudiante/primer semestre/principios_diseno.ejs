<script>
    // Toggle sidebar
    document.getElementById('menuToggle').addEventListener('click', function() {
        document.getElementById('sidebar').classList.toggle('collapsed');
    });

    // Mostrar sidebar por defecto en principios_diseno
    document.addEventListener('DOMContentLoaded', function() {
        const sidebar = document.getElementById('sidebar');
        const fundamentosSubjects = document.getElementById('fundamentos-subjects');
        const fundamentosIcon = document.getElementById('fundamentos-icon');
        
        // Expandir automáticamente los subtemas de primer semestre
        if (fundamentosSubjects && fundamentosIcon) {
            fundamentosSubjects.classList.add('show');
            fundamentosIcon.classList.add('rotated');
        }
    });

    // Toggle Fundamentos de Diseño subjects
    document.getElementById('fundamentos-toggle').addEventListener('click', function(e) {
        const subjects = document.getElementById('fundamentos-subjects');
        const icon = document.getElementById('fundamentos-icon');
        
        if (subjects.classList.contains('show')) {
            subjects.classList.remove('show');
            icon.classList.remove('rotated');
        } else {
            subjects.classList.add('show');
            icon.classList.add('rotated');
        }
    });

    // Toggle Teoría y Métodos subjects
    document.getElementById('teoria-toggle').addEventListener('click', function(e) {
        const subjects = document.getElementById('teoria-subjects');
        const icon = document.getElementById('teoria-icon');
        
        if (subjects.classList.contains('show')) {
            subjects.classList.remove('show');
            icon.classList.remove('rotated');
        } else {
            subjects.classList.add('show');
            icon.classList.add('rotated');
        }
    });

    // Toggle Diseño y Biónica subjects
    document.getElementById('diseno-toggle').addEventListener('click', function(e) {
        const subjects = document.getElementById('diseno-subjects');
        const icon = document.getElementById('diseno-icon');
        
        if (subjects.classList.contains('show')) {
            subjects.classList.remove('show');
            icon.classList.remove('rotated');
        } else {
            subjects.classList.add('show');
            icon.classList.add('rotated');
        }
    });

    // Search functionality
    document.querySelector('.search-input').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            const searchTerm = e.target.value;
            console.log('Buscando:', searchTerm);
            // Implementar lógica de búsqueda
        }
    });

    // ── Flip cards ──────────────────────────────────────────
    const concepts = [
        { label: 'Navaja de Ockham',           icon: '✂️' },
        { label: 'Usabilidad Estética',         icon: '✦'  },
        { label: 'Jerarquía',                   icon: '◈'  },
        { label: 'Ley de Fitts',                icon: '⊙'  },
        { label: 'Asequibilidad',               icon: '✋' },
        { label: 'Señal-Ruido',                 icon: '≈'  },
    ];

    const grid = document.getElementById('cards-grid');
    concepts.forEach(function (item) {
        const card = document.createElement('div');
        card.className = 'flip-card';
        card.innerHTML =
            '<div class="flip-inner">' +
            '<div class="flip-front">' +
            '<div class="flip-icon-wrap">' + item.icon + '</div>' +
            '<div class="flip-label">'     + item.label + '</div>' +
            '<div class="flip-hint">▸ clic para video</div>' +
            '</div>' +
            '<div class="flip-back">' +
            '<div class="flip-back-play"><div class="back-play-icon"></div></div>' +
            '<div class="flip-back-label">' + item.label + '</div>' +
            '</div>' +
            '</div>';
        card.addEventListener('click', function () { card.classList.toggle('flipped'); });
        grid.appendChild(card);
    });

    // ── Highlight active anchor on scroll ──────────────────
    const sections = document.querySelectorAll('.section-block');
    const navLinks = document.querySelectorAll('.anchor-nav a');

    const observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
            if (entry.isIntersecting) {
                navLinks.forEach(function (l) { l.classList.remove('active'); });
                var active = document.querySelector('.anchor-nav a[href="#' + entry.target.id + '"]');
                if (active) active.classList.add('active');
            }
        });
    }, { rootMargin: '-120px 0px -60% 0px' });

    sections.forEach(function (s) { observer.observe(s); });
</script>
