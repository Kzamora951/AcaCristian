    <script>
        // Toggle sidebar
        document.getElementById('menuToggle').addEventListener('click', function() {
            document.getElementById('sidebar').classList.toggle('collapsed');
        });

        // Toggle Fundamentos de Diseño subjects
        document.getElementById('fundamentos-toggle').addEventListener('click', function(e) {
            e.preventDefault();
            const subjects = document.getElementById('fundamentos-subjects');
            const icon = document.getElementById('fundamentos-icon');
            
            if (subjects.classList.contains('show')) {
                subjects.classList.remove('show');
                icon.classList.remove('rotated');
            } else {
                subjects.classList.add('show');
                icon.classList.add('rotated');
            }
        });

        // Toggle Teoría y Métodos subjects
        document.getElementById('teoria-toggle').addEventListener('click', function(e) {
            e.preventDefault();
            const subjects = document.getElementById('teoria-subjects');
            const icon = document.getElementById('teoria-icon');
            
            if (subjects.classList.contains('show')) {
                subjects.classList.remove('show');
                icon.classList.remove('rotated');
            } else {
                subjects.classList.add('show');
                icon.classList.add('rotated');
            }
        });

        // Toggle Diseño y Bionica subjects
        document.getElementById('diseno-toggle').addEventListener('click', function(e) {
            e.preventDefault();
            const subjects = document.getElementById('diseno-subjects');
            const icon = document.getElementById('diseno-icon');
            
            if (subjects.classList.contains('show')) {
                subjects.classList.remove('show');
